{
  "name": "super-mario",
  "version": "0.1.0",
  "description": "Classic 2D side-scrolling platformer built with Phaser 3 + TypeScript",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "format": "prettier --write src tests",
    "test": "vitest run --passWithNoTests",
    "levels": "node scripts/design-levels.mjs && node scripts/gen-level.mjs && node scripts/lint-levels.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkchuang/super_mario.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/mkchuang/super_mario/issues"
  },
  "homepage": "https://github.com/mkchuang/super_mario#readme",
  "dependencies": {
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "private": true
}
